// BSC Event Ticketing Platform - Prisma Schema
// Based on ERD_v2.md - MVP (Phase 1) Tables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================
// MODULE 1: USER MANAGEMENT
// ===========================================

model User {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  email           String   @unique
  phone           String?  @unique
  passwordHash    String?  @map("password_hash")
  role            UserRole @default(CUSTOMER)
  isVerified      Boolean  @default(false) @map("is_verified")
  isActive        Boolean  @default(true) @map("is_active")
  avatarUrl       String?  @map("avatar_url")
  locale          String   @default("id")
  timezone        String   @default("Asia/Jakarta")
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Relations
  organizerProfile  OrganizerProfile?
  customerProfile   CustomerProfile?
  bookings          Booking[]
  events            Event[]
  reviews           Review[]
  wishlists         Wishlist[]
  notifications     Notification[]

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  CUSTOMER
  SCANNER
}

model OrganizerProfile {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String   @unique @map("user_id") @db.Uuid
  organizationName       String   @map("organization_name")
  organizationSlug       String   @unique @map("organization_slug")
  organizationLogo       String?  @map("organization_logo")
  organizationBanner     String?  @map("organization_banner")
  organizationDescription String? @map("organization_description")
  websiteUrl             String?  @map("website_url")
  socialFacebook         String?  @map("social_facebook")
  socialInstagram        String?  @map("social_instagram")
  socialTwitter          String?  @map("social_twitter")
  socialTiktok           String?  @map("social_tiktok")
  walletBalance          Decimal  @default(0) @map("wallet_balance") @db.Decimal(15, 2)
  totalEarned            Decimal  @default(0) @map("total_earned") @db.Decimal(15, 2)
  totalWithdrawn         Decimal  @default(0) @map("total_withdrawn") @db.Decimal(15, 2)
  isVerified             Boolean  @default(false) @map("is_verified")
  verificationStatus     VerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt             DateTime? @map("verified_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts OrganizerBankAccount[]
  payouts      Payout[]

  @@map("organizer_profiles")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrganizerBankAccount {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizerProfileId String  @map("organizer_profile_id") @db.Uuid
  bankName          String   @map("bank_name")
  bankCode          String?  @map("bank_code")
  accountNumber     String   @map("account_number")
  accountHolderName String   @map("account_holder_name")
  isPrimary         Boolean  @default(false) @map("is_primary")
  isVerified        Boolean  @default(false) @map("is_verified")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  organizerProfile OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  payouts          Payout[]

  @@map("organizer_bank_accounts")
}

model CustomerProfile {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @unique @map("user_id") @db.Uuid
  birthDate  DateTime? @map("birth_date") @db.Date
  gender     Gender?
  address    String?
  city       String?
  province   String?
  postalCode String?   @map("postal_code")
  idNumber   String?   @map("id_number")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ===========================================
// MODULE 2: EVENT MANAGEMENT
// ===========================================

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  icon      String?
  colorHex  String?  @map("color_hex")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Self-relation for subcategories
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  events   Event[]

  @@map("categories")
}

model Venue {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizerId   String?  @map("organizer_id") @db.Uuid
  name          String
  slug          String   @unique
  address       String
  city          String
  province      String
  postalCode    String?  @map("postal_code")
  country       String   @default("Indonesia")
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)
  googlePlaceId String?  @map("google_place_id")
  capacity      Int?
  description   String?
  amenities     Json?
  imageUrl      String?  @map("image_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  events Event[]

  @@map("venues")
}

model Event {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizerId         String          @map("organizer_id") @db.Uuid
  categoryId          String          @map("category_id") @db.Uuid
  venueId             String?         @map("venue_id") @db.Uuid
  title               String
  slug                String          @unique
  shortDescription    String?         @map("short_description") @db.VarChar(200)
  description         String?
  posterImage         String?         @map("poster_image")
  bannerImage         String?         @map("banner_image")
  trailerVideoUrl     String?         @map("trailer_video_url")
  eventType           EventType       @default(OFFLINE) @map("event_type")
  status              EventStatus     @default(DRAFT)
  visibility          EventVisibility @default(PUBLIC)
  accessPassword      String?         @map("access_password")
  isFeatured          Boolean         @default(false) @map("is_featured")
  isRecurring         Boolean         @default(false) @map("is_recurring")
  hasSeatingChart     Boolean         @default(false) @map("has_seating_chart")
  requiresApproval    Boolean         @default(false) @map("requires_approval")
  minTicketsPerOrder  Int             @default(1) @map("min_tickets_per_order")
  maxTicketsPerOrder  Int             @default(10) @map("max_tickets_per_order")
  onlineMeetingUrl    String?         @map("online_meeting_url")
  onlineMeetingPassword String?       @map("online_meeting_password")
  termsAndConditions  String?         @map("terms_and_conditions")
  refundPolicy        String?         @map("refund_policy")
  metaTitle           String?         @map("meta_title")
  metaDescription     String?         @map("meta_description")
  metaKeywords        String?         @map("meta_keywords")
  viewCount           Int             @default(0) @map("view_count")
  publishAt           DateTime?       @map("publish_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  deletedAt           DateTime?       @map("deleted_at")

  // Relations
  organizer       User              @relation(fields: [organizerId], references: [id])
  category        Category          @relation(fields: [categoryId], references: [id])
  venue           Venue?            @relation(fields: [venueId], references: [id])
  schedules       EventSchedule[]
  ticketTypes     TicketType[]
  bookings        Booking[]
  promoCodes      PromoCode[]
  reviews         Review[]
  wishlists       Wishlist[]
  faqs            EventFaq[]
  deviceSessions  EventDeviceSession[]
  eventTags       EventTag[]
  eventMedia      EventMedia[]
  eventPerformers EventPerformer[]
  eventSponsors   EventSponsor[]
  venueSections   VenueSection[]

  @@map("events")
}

enum EventType {
  OFFLINE
  ONLINE
  HYBRID
}

enum EventStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  CANCELLED
  ENDED
}

enum EventVisibility {
  PUBLIC
  PRIVATE
  PASSWORD_PROTECTED
}

model EventSchedule {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String    @map("event_id") @db.Uuid
  title            String?
  scheduleDate     DateTime  @map("schedule_date") @db.Date
  startTime        DateTime  @map("start_time") @db.Time()
  endTime          DateTime  @map("end_time") @db.Time()
  description      String?
  locationOverride String?   @map("location_override")
  sortOrder        Int       @default(0) @map("sort_order")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")

  // Relations
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("event_schedules")
}

model EventFaq {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_faqs")
}

// ===========================================
// MODULE 3: TICKETING
// ===========================================

model TicketType {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId              String    @map("event_id") @db.Uuid
  name                 String
  description          String?
  basePrice            Decimal   @map("base_price") @db.Decimal(15, 2)
  currency             String    @default("IDR")
  totalQuantity        Int       @map("total_quantity")
  soldQuantity         Int       @default(0) @map("sold_quantity")
  reservedQuantity     Int       @default(0) @map("reserved_quantity")
  minPerOrder          Int       @default(1) @map("min_per_order")
  maxPerOrder          Int       @default(10) @map("max_per_order")
  isFree               Boolean   @default(false) @map("is_free")
  isHidden             Boolean   @default(false) @map("is_hidden")
  requiresAttendeeInfo Boolean   @default(false) @map("requires_attendee_info")
  isTransferable       Boolean   @default(true) @map("is_transferable")
  saleStartAt          DateTime? @map("sale_start_at")
  saleEndAt            DateTime? @map("sale_end_at")
  sortOrder            Int       @default(0) @map("sort_order")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  priceTiers    TicketPriceTier[]
  bookedTickets BookedTicket[]
  seats         Seat[]

  @@map("ticket_types")
}

model TicketPriceTier {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketTypeId  String   @map("ticket_type_id") @db.Uuid
  name          String
  price         Decimal  @db.Decimal(15, 2)
  quantityLimit Int?     @map("quantity_limit")
  soldQuantity  Int      @default(0) @map("sold_quantity")
  startAt       DateTime @map("start_at")
  endAt         DateTime @map("end_at")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  ticketType    TicketType     @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  bookedTickets BookedTicket[]

  @@map("ticket_price_tiers")
}

model PromoCode {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId               String?     @map("event_id") @db.Uuid
  organizerId           String      @map("organizer_id") @db.Uuid
  code                  String      @unique
  description           String?
  discountType          DiscountType @map("discount_type")
  discountValue         Decimal     @map("discount_value") @db.Decimal(15, 2)
  maxDiscountAmount     Decimal?    @map("max_discount_amount") @db.Decimal(15, 2)
  minOrderAmount        Decimal?    @map("min_order_amount") @db.Decimal(15, 2)
  usageLimitTotal       Int?        @map("usage_limit_total")
  usageLimitPerUser     Int?        @map("usage_limit_per_user")
  usedCount             Int         @default(0) @map("used_count")
  applicableTicketTypes Json?       @map("applicable_ticket_types")
  validFrom             DateTime    @map("valid_from")
  validUntil            DateTime    @map("valid_until")
  isActive              Boolean     @default(true) @map("is_active")
  createdAt             DateTime    @default(now()) @map("created_at")

  // Relations
  event  Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  usages PromoCodeUsage[]

  @@map("promo_codes")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model PromoCodeUsage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promoCodeId    String   @map("promo_code_id") @db.Uuid
  bookingId      String   @map("booking_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  discountAmount Decimal  @map("discount_amount") @db.Decimal(15, 2)
  usedAt         DateTime @default(now()) @map("used_at")

  // Relations
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  booking   Booking   @relation(fields: [bookingId], references: [id])

  @@map("promo_code_usages")
}

// ===========================================
// MODULE 4: BOOKING & TRANSACTIONS
// ===========================================

model Booking {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingCode       String         @unique @map("booking_code")
  userId            String?        @map("user_id") @db.Uuid
  eventId           String         @map("event_id") @db.Uuid
  eventScheduleId   String?        @map("event_schedule_id") @db.Uuid
  guestEmail        String?        @map("guest_email")
  guestName         String?        @map("guest_name")
  guestPhone        String?        @map("guest_phone")
  totalTickets      Int            @map("total_tickets")
  subtotal          Decimal        @db.Decimal(15, 2)
  discountAmount    Decimal        @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxAmount         Decimal        @default(0) @map("tax_amount") @db.Decimal(15, 2)
  platformFee       Decimal        @default(0) @map("platform_fee") @db.Decimal(15, 2)
  paymentGatewayFee Decimal        @default(0) @map("payment_gateway_fee") @db.Decimal(15, 2)
  totalAmount       Decimal        @map("total_amount") @db.Decimal(15, 2)
  organizerRevenue  Decimal        @default(0) @map("organizer_revenue") @db.Decimal(15, 2)
  platformRevenue   Decimal        @default(0) @map("platform_revenue") @db.Decimal(15, 2)
  status            BookingStatus  @default(PENDING)
  paymentStatus     PaymentStatus  @default(UNPAID) @map("payment_status")
  salesChannel      SalesChannel   @default(ONLINE) @map("sales_channel")
  soldByStaff       String?        @map("sold_by_staff")
  soldByDevice      String?        @map("sold_by_device")
  cancellationReason String?       @map("cancellation_reason")
  cancelledBy       String?        @map("cancelled_by") @db.Uuid
  cancelledAt       DateTime?      @map("cancelled_at")
  ipAddress         String?        @map("ip_address")
  userAgent         String?        @map("user_agent")
  utmParams         Json?          @map("utm_params")
  expiresAt         DateTime?      @map("expires_at")
  paidAt            DateTime?      @map("paid_at")
  confirmedAt       DateTime?      @map("confirmed_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // Relations
  user           User?           @relation(fields: [userId], references: [id])
  event          Event           @relation(fields: [eventId], references: [id])
  eventSchedule  EventSchedule?  @relation(fields: [eventScheduleId], references: [id])
  bookedTickets  BookedTicket[]
  transaction    Transaction?
  promoCodeUsage PromoCodeUsage[]
  refunds        Refund[]

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  CONFIRMED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIAL_REFUND
  FULL_REFUND
}

enum SalesChannel {
  ONLINE
  ON_SITE
}

model BookedTicket {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId          String            @map("booking_id") @db.Uuid
  ticketTypeId       String            @map("ticket_type_id") @db.Uuid
  ticketPriceTierId  String?           @map("ticket_price_tier_id") @db.Uuid
  seatId             String?           @map("seat_id") @db.Uuid
  uniqueCode         String            @unique @map("unique_code")
  qrCodeUrl          String?           @map("qr_code_url")
  unitPrice          Decimal           @map("unit_price") @db.Decimal(15, 2)
  taxAmount          Decimal           @default(0) @map("tax_amount") @db.Decimal(15, 2)
  finalPrice         Decimal           @map("final_price") @db.Decimal(15, 2)
  isCheckedIn        Boolean           @default(false) @map("is_checked_in")
  checkedInAt        DateTime?         @map("checked_in_at")
  checkedInBy        String?           @map("checked_in_by") @db.Uuid
  checkInPointId     String?           @map("check_in_point_id") @db.Uuid
  status             BookedTicketStatus @default(ACTIVE)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  // Relations
  booking       Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType    TicketType       @relation(fields: [ticketTypeId], references: [id])
  priceTier     TicketPriceTier? @relation(fields: [ticketPriceTierId], references: [id])
  checkInLogs   CheckInLog[]

  @@map("booked_tickets")
}

enum BookedTicketStatus {
  ACTIVE
  TRANSFERRED
  CANCELLED
  REFUNDED
}

model Transaction {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId            String            @unique @map("booking_id") @db.Uuid
  transactionCode      String            @unique @map("transaction_code")
  paymentGateway       String            @map("payment_gateway")
  paymentMethod        String            @map("payment_method")
  paymentChannel       String?           @map("payment_channel")
  amount               Decimal           @db.Decimal(15, 2)
  currency             String            @default("IDR")
  status               TransactionStatus @default(PENDING)
  gatewayResponse      Json?             @map("gateway_response")
  gatewayTransactionId String?           @map("gateway_transaction_id")
  failureReason        String?           @map("failure_reason")
  paidAt               DateTime?         @map("paid_at")
  expiresAt            DateTime?         @map("expires_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  // Relations
  booking Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@map("transactions")
}

enum TransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  REFUNDED
}

// ===========================================
// MODULE 5: CHECK-IN SYSTEM
// ===========================================

model CheckInLog {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookedTicketId  String         @map("booked_ticket_id") @db.Uuid
  scannedBy       String         @map("scanned_by") @db.Uuid
  checkInPointId  String?        @map("check_in_point_id") @db.Uuid
  result          CheckInResult
  scannedCode     String         @map("scanned_code")
  deviceInfo      String?        @map("device_info")
  ipAddress       String?        @map("ip_address")
  scannedAt       DateTime       @default(now()) @map("scanned_at")

  // Relations
  bookedTicket BookedTicket @relation(fields: [bookedTicketId], references: [id])

  @@map("check_in_logs")
}

enum CheckInResult {
  SUCCESS
  ALREADY_CHECKED_IN
  INVALID
  EXPIRED
  WRONG_EVENT
}

// ===========================================
// MODULE 6: FINANCIAL
// ===========================================

model Refund {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId  String       @map("transaction_id") @db.Uuid
  bookingId      String       @map("booking_id") @db.Uuid
  requestedBy    String       @map("requested_by") @db.Uuid
  processedBy    String?      @map("processed_by") @db.Uuid
  refundType     RefundType   @map("refund_type")
  refundAmount   Decimal      @map("refund_amount") @db.Decimal(15, 2)
  reason         String?
  status         RefundStatus @default(REQUESTED)
  gatewayRefundId String?     @map("gateway_refund_id")
  gatewayResponse Json?       @map("gateway_response")
  adminNotes     String?      @map("admin_notes")
  requestedAt    DateTime     @default(now()) @map("requested_at")
  processedAt    DateTime?    @map("processed_at")
  completedAt    DateTime?    @map("completed_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  // Relations
  transaction Transaction @relation(fields: [transactionId], references: [id])
  booking     Booking     @relation(fields: [bookingId], references: [id])

  @@map("refunds")
}

enum RefundType {
  FULL
  PARTIAL
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

model Payout {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizerId     String       @map("organizer_id") @db.Uuid
  bankAccountId   String       @map("bank_account_id") @db.Uuid
  payoutCode      String       @unique @map("payout_code")
  amount          Decimal      @db.Decimal(15, 2)
  fee             Decimal      @default(0) @db.Decimal(15, 2)
  netAmount       Decimal      @map("net_amount") @db.Decimal(15, 2)
  status          PayoutStatus @default(REQUESTED)
  notes           String?
  rejectionReason String?      @map("rejection_reason")
  proofDocumentUrl String?     @map("proof_document_url")
  requestedBy     String       @map("requested_by") @db.Uuid
  processedBy     String?      @map("processed_by") @db.Uuid
  requestedAt     DateTime     @default(now()) @map("requested_at")
  approvedAt      DateTime?    @map("approved_at")
  completedAt     DateTime?    @map("completed_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  // Relations
  organizerProfile OrganizerProfile     @relation(fields: [organizerId], references: [id])
  bankAccount      OrganizerBankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("payouts")
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

// ===========================================
// MODULE 7: REVIEWS & ENGAGEMENT
// ===========================================

model Review {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  eventId    String       @map("event_id") @db.Uuid
  bookingId  String       @map("booking_id") @db.Uuid
  rating     Int
  reviewText String?      @map("review_text")
  isVerified Boolean      @default(true) @map("is_verified")
  status     ReviewStatus @default(PUBLISHED)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

