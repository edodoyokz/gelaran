model VenueSection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  name        String
  colorHex    String?  @map("color_hex")
  sortOrder   Int      @default(0) @map("sort_order")
  capacity    Int?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rows  VenueRow[]

  @@map("venue_sections")
}

model VenueRow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId   String   @map("section_id") @db.Uuid
  rowLabel    String   @map("row_label")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  section VenueSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  seats   Seat[]

  @@map("venue_rows")
}

model Seat {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rowId           String     @map("row_id") @db.Uuid
  ticketTypeId    String?    @map("ticket_type_id") @db.Uuid
  seatLabel       String     @map("seat_label")
  seatNumber      Int        @map("seat_number")
  status          SeatStatus @default(AVAILABLE)
  priceOverride   Decimal?   @map("price_override") @db.Decimal(15, 2)
  isAccessible    Boolean    @default(false) @map("is_accessible")
  lockedByUserId  String?    @map("locked_by_user_id") @db.Uuid
  lockedUntil     DateTime?  @map("locked_until")
  bookedTicketId  String?    @map("booked_ticket_id") @db.Uuid
  sortOrder       Int        @default(0) @map("sort_order")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")

  row         VenueRow     @relation(fields: [rowId], references: [id], onDelete: Cascade)
  ticketType  TicketType?  @relation(fields: [ticketTypeId], references: [id])

  @@unique([rowId, seatNumber])
  @@map("seats")
}

enum SeatStatus {
  AVAILABLE
  LOCKED
  BOOKED
  BLOCKED
  RESERVED
}

