# ============================================
# BSC Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# DATABASE (PostgreSQL via Supabase)
# ============================================
# Connection string with connection pooling (for Prisma Client)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for migrations)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ============================================
# SUPABASE (Auth & Storage)
# ============================================
# Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"

# Anon key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Service role key (server-side only, keep secret!)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ============================================
# MIDTRANS (Payment Gateway - enable after beta)
# ============================================
# Required only when NEXT_PUBLIC_PAYMENTS_ENABLED="true"
# Set to "true" for production, "false" for sandbox
MIDTRANS_IS_PRODUCTION="false"

# Server key from Midtrans dashboard
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxxx"

# Client key (safe for client-side)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxxx"

# ============================================
# EMAIL (Resend)
# ============================================
# API key from Resend dashboard
RESEND_API_KEY="re_xxxxxxxxxxxxx"

# From address used by outgoing emails
EMAIL_FROM="BSC Events <noreply@yourdomain.com>"

# ============================================
# APPLICATION
# ============================================
# Base URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# App stage:
# - local: developer machine / sandbox behavior allowed
# - beta: complimentary ticket beta, no live payments
# - production: launch-ready environment
NEXT_PUBLIC_APP_STAGE="local"

# Enable live payments only after beta.
NEXT_PUBLIC_PAYMENTS_ENABLED="false"

# Shared secret for internal cron endpoints
CRON_SECRET="replace-with-a-long-random-secret"

# Optional webhook for operational alerts outside of health probes
OPS_ALERT_WEBHOOK_URL=""

# ============================================
# DEMO MODE (Local Development Only)
# ============================================
# Enable demo payment flow (bypasses Midtrans, simulates instant success)
# WARNING: Only enable in local stage. Beta should use complimentary tickets.
NEXT_PUBLIC_ENABLE_DEMO_PAYMENT="false"

# Optional override for Midtrans Snap script URL
# NEXT_PUBLIC_MIDTRANS_SNAP_URL="https://app.sandbox.midtrans.com/snap/snap.js"
