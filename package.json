{
  "name": "bsc-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test:env": "node --import tsx --test lib/env.test.ts",
    "setup:storage": "npx tsx scripts/setup-storage.ts",
    "test:demo-mode": "node --import tsx --test lib/demo-mode.test.ts",
    "test:logging": "node --import tsx --test lib/logging-request.test.ts",
    "test:platform-settings": "node --import tsx --test lib/platform-settings.test.ts",
    "test": "pnpm run test:env && pnpm run test:demo-mode && pnpm run test:logging && pnpm run test:platform-settings && pnpm run test:layout-fonts && pnpm run test:prisma-config && pnpm run test:complimentary-flow && pnpm run test:cron-auth && pnpm run test:stage-guard && pnpm run test:payments && pnpm run test:rate-limit && pnpm run test:health && pnpm run test:auth-route-coverage && pnpm run test:auth-recovery-ui && pnpm run test:route-contracts",
    "verify": "pnpm run lint && pnpm run test && pnpm run typecheck && pnpm run build:verify",
    "build:verify": "node scripts/run-build-with-ci-env.mjs",
    "test:layout-fonts": "node --import tsx --test lib/layout-fonts.test.ts",
    "build:ci": "CI_BUILD_SKIP_NEXT_TYPECHECK=true CI_BUILD_DISABLE_WEBPACK_WORKER=true prisma generate && next build --webpack",
    "typecheck": "tsc --noEmit",
    "test:prisma-config": "node --import tsx --test lib/prisma-config.test.ts",
    "test:complimentary-flow": "node --import tsx --test lib/complimentary-flow.test.ts",
    "test:cron-auth": "node --import tsx --test lib/cron-auth.test.ts",
    "test:stage-guard": "node --import tsx --test lib/payments/stage-guard.test.ts",
    "test:payments": "node --import tsx --test lib/payments/audit-payloads.test.ts lib/payments/idempotency.test.ts lib/payments/webhook-transitions.test.ts lib/payments/pos-retry.test.ts",
    "test:rate-limit": "node --import tsx --test lib/rate-limit.test.ts",
    "test:health": "node --import tsx --test lib/health.test.ts",
    "test:auth-route-coverage": "node --import tsx --test lib/auth/route-auth-coverage.test.ts",
    "test:auth-recovery-ui": "node --import tsx --test lib/auth-recovery-ui.test.ts",
    "test:route-contracts": "node --import tsx --test lib/route-contracts.test.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.1",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-query": "^5.90.16",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.562.0",
    "midtrans-client": "^1.4.3",
    "next": "16.1.6",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.70.0",
    "recharts": "^3.6.0",
    "resend": "^6.7.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@jest/globals": "^30.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "playwright": "^1.59.1",
    "prisma": "^6.19.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.13.5",
      "lodash": "4.17.23"
    }
  },
  "packageManager": "pnpm@10.28.0"
}
